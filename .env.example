# ───── Database ─────
DATABASE_URL=postgresql+asyncpg://hermes:hermes@localhost:5432/hermes
DATABASE_URL_SYNC=postgresql://hermes:hermes@localhost:5432/hermes
WEB_DATABASE_URL=postgresql://hermes:hermes@localhost:5432/hermes

# ───── Redis / Celery ─────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ───── Object storage (MinIO / S3) ─────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=hermes
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ───── Auth.js / NextAuth ─────
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=change-me-with-openssl-rand-base64-32
AUTH_TRUST_HOST=true

# Credenciais do único usuário (acesso privado)
HERMES_USER_EMAIL=admin@hermes.local
HERMES_USER_PASSWORD=hermes

# ───── LLM ─────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Modelo usado pra anonimizar PII antes de mandar pra análise.
# Flash é suficiente e custa ~R$ 0,02 por caso.
GEMINI_ANONYMIZER_MODEL=gemini-2.5-flash

# ───── API ─────
API_PORT=8000
API_BASE_URL=http://localhost:8000
HERMES_API_URL=http://localhost:8000
HERMES_INTERNAL_SECRET=change-me-shared-between-web-and-api
CORS_ORIGINS=http://localhost:3000

# ───── Playwright capture ─────
PLAYWRIGHT_SERVICE_URL=http://localhost:8001
BEM_TE_VI_PROFILE_DIR=./bem_te_vi_profile
# Liga captura real (chromium); por padrão usa stub
BEMTEVI_REAL_CAPTURE=0
# URL de consulta com placeholder {numero_processo}
BEMTEVI_LOOKUP_URL_TEMPLATE=
BEMTEVI_HEADLESS=1
BEMTEVI_NAV_TIMEOUT=30000
