# ───── Database ─────
DATABASE_URL=postgresql+asyncpg://hermes:hermes@localhost:5432/hermes
DATABASE_URL_SYNC=postgresql://hermes:hermes@localhost:5432/hermes
WEB_DATABASE_URL=postgresql://hermes:hermes@localhost:5432/hermes

# ───── Redis / Celery ─────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ───── Object storage (MinIO / S3) ─────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=hermes
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ───── Auth.js / NextAuth ─────
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=change-me-with-openssl-rand-base64-32
AUTH_TRUST_HOST=true
AUTH_RESEND_KEY=re_xxx
AUTH_EMAIL_FROM=hermes@example.com

# Dev SMTP (Mailhog) — usado quando AUTH_RESEND_KEY não estiver setada
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=

# ───── LLM ─────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ───── API ─────
API_PORT=8000
API_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000

# ───── Playwright capture ─────
PLAYWRIGHT_SERVICE_URL=http://localhost:8001
BEM_TE_VI_PROFILE_DIR=./bem_te_vi_profile
